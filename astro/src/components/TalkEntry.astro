---
interface Link {
  label: string;
  href: string;
}

interface Props {
  title: string;
  date: string;
  venue: string;
  description?: string;
  links?: Link[];
  upcoming?: boolean;
}

const { title, date, venue, description, links = [], upcoming = false } = Astro.props;
---

<div class="flex flex-col md:flex-row gap-1 md:gap-4 py-5 border-b border-border-dark light:border-border-light last:border-b-0">
  <div class="md:w-24 md:flex-shrink-0 text-xs text-muted-dark light:text-muted-light pt-0.5 leading-relaxed">
    {date}
  </div>

  <div class="flex flex-col gap-1 flex-1 min-w-0">
    <div class="flex flex-wrap items-center gap-2">
      <span class="font-medium text-sm text-text-dark light:text-text-light leading-snug">{title}</span>
      {upcoming && (
        <span class="text-[10px] bg-[#222] light:bg-[#eee] rounded-full px-2 py-0.5 text-muted-dark light:text-muted-light flex-shrink-0">
          upcoming
        </span>
      )}
    </div>

    <span class="text-xs text-muted-dark light:text-muted-light">{venue}</span>

    {description && (
      <p class="text-xs text-muted-dark light:text-muted-light leading-relaxed mt-0.5">{description}</p>
    )}

    {links.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-2">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-[11px] font-medium px-2.5 py-1 rounded-md border border-[#2a2a2a] light:border-[#d0d0d0] bg-[#141414] light:bg-[#f2f2f2] text-[#c0c0c0] light:text-[#333] hover:text-white light:hover:text-black hover:border-[#444] light:hover:border-[#b0b0b0] hover:bg-[#1c1c1c] light:hover:bg-[#ebebeb] transition-colors"
          >
            {link.label}
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60">
              <path d="M7 17L17 7M17 7H8M17 7V16" />
            </svg>
          </a>
        ))}
      </div>
    )}
  </div>
</div>
