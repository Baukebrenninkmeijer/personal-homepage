---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const topics = [
  'AI Agents',
  'LLM Evaluation',
  'LLMOps',
  'Fine-tuning & Prompt Engineering',
  'Synthetic Data',
];
---

<section class="animate-fade-in max-w-5xl mx-auto px-6 py-28 md:py-36 flex flex-col gap-20">

  <!-- 1. Hero -->
  <div class="flex flex-col md:flex-row items-center md:items-start gap-10 md:gap-16">

    <!-- Text block -->
    <div class="flex flex-col items-center md:items-start gap-5 flex-1 text-center md:text-left">
      <div>
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-text-dark light:text-text-light">
          Bauke Brenninkmeijer
        </h1>
        <p class="mt-3 text-lg md:text-xl leading-relaxed text-text-dark light:text-text-light max-w-xl">
          AI Research Engineer at orq.ai. I build AI agent infrastructure, evaluate LLMs, and write about getting models into production.
        </p>
      </div>

      <!-- CTA buttons -->
      <div class="flex items-center gap-3">
        <a
          href={`${base}/projects`}
          class="px-4 py-2 rounded text-sm font-medium bg-text-dark text-bg-dark light:bg-text-light light:text-bg-light hover:opacity-80 transition-opacity"
        >
          View Projects
        </a>
        <a
          href={`${base}/blog`}
          class="px-4 py-2 border border-border-dark light:border-border-light rounded text-sm font-medium text-muted-dark light:text-muted-light hover:text-text-dark hover:border-text-dark light:hover:text-text-light light:hover:border-text-light transition-colors"
        >
          Read Blog
        </a>
      </div>
    </div>

    <!-- Overlapping photos: real in front, cartoon behind -->
    <div class="flex-shrink-0 photo-pair relative w-52 h-44">
      <img
        src="/cartoon-avatar.jpg"
        alt="Cartoon avatar of Bauke"
        class="absolute left-0 top-2 w-36 h-36 rounded-full border-2 border-border-dark light:border-border-light object-cover z-10 transition-transform duration-300"
      />
      <img
        src="/profile.jpg"
        alt="Photo of Bauke Brenninkmeijer"
        class="absolute left-16 top-0 w-36 h-36 rounded-full border-2 border-border-dark light:border-border-light object-cover z-20 transition-transform duration-300"
      />
    </div>

  </div>

  <!-- 2. About -->
  <div class="border-t border-border-dark light:border-border-light pt-10">
    <h2 class="text-2xl font-bold text-text-dark light:text-text-light mb-5">About</h2>
    <div class="space-y-4 text-base text-muted-dark light:text-muted-light leading-relaxed max-w-2xl">
      <p>
        I'm an AI Research Engineer with a background in data science and computer science. After working at several startups, I spent 5 years building ML systems at ABN AMRO and ING — from real-time streaming frameworks to RAG-based document processing.
      </p>
      <p>
        Now at <a href="https://orq.ai" class="underline hover:text-text-dark light:hover:text-text-light transition-colors">orq.ai</a>, I focus on AI agent infrastructure, LLM evaluation, and figuring out what actually makes models work in production.
      </p>
      <p>
        I co-organize the <a href="https://mlops.community/" class="underline hover:text-text-dark light:hover:text-text-light transition-colors">MLOps Community Amsterdam</a> meetup and speak at conferences about applied AI.
      </p>
    </div>
  </div>

  <!-- 3. Technical Arsenal -->
  <div class="border-t border-border-dark light:border-border-light pt-10">
    <h2 class="text-2xl font-bold text-text-dark light:text-text-light mb-6">Technical Arsenal</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-sm font-semibold text-text-dark light:text-text-light mb-3 pb-2 border-b border-border-dark light:border-border-light">AI & LLMs</h3>
        <div class="flex flex-wrap gap-2">
          {['LLM Evaluation', 'Agent Orchestration', 'RAG', 'Fine-tuning', 'Prompt Engineering', 'vLLM', 'LangChain'].map(s => (
            <span class="text-xs border border-border-dark light:border-border-light rounded-full px-3 py-1 text-muted-dark light:text-muted-light">{s}</span>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text-dark light:text-text-light mb-3 pb-2 border-b border-border-dark light:border-border-light">Data & ML</h3>
        <div class="flex flex-wrap gap-2">
          {['Python', 'PyTorch', 'Polars', 'Spark', 'Pandas', 'scikit-learn', 'GANs', 'Synthetic Data'].map(s => (
            <span class="text-xs border border-border-dark light:border-border-light rounded-full px-3 py-1 text-muted-dark light:text-muted-light">{s}</span>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text-dark light:text-text-light mb-3 pb-2 border-b border-border-dark light:border-border-light">Infrastructure</h3>
        <div class="flex flex-wrap gap-2">
          {['Azure', 'Databricks', 'Docker', 'MLflow', 'CI/CD', 'Kubernetes'].map(s => (
            <span class="text-xs border border-border-dark light:border-border-light rounded-full px-3 py-1 text-muted-dark light:text-muted-light">{s}</span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- 4. Contact CTA card -->
  <div class="max-w-lg mx-auto md:mx-0 border border-border-dark light:border-border-light rounded-xl p-7">
    <p class="text-xs uppercase tracking-widest text-muted-dark light:text-muted-light mb-3">Get in touch</p>
    <h2 class="text-lg font-semibold text-text-dark light:text-text-light mb-2">Available for speaking and collaboration</h2>
    <p class="text-sm text-muted-dark light:text-muted-light mb-4">Interested in AI agents, LLM evaluation, or production ML? Let's talk.</p>

    <div class="flex gap-3">
      <a
        href="https://calendar.app.google/7ET48JSCNjYVgiLH7"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center px-4 py-2.5 rounded-lg text-sm font-semibold bg-text-dark text-bg-dark light:bg-text-light light:text-bg-light hover:opacity-80 transition-opacity"
      >
        Schedule a call
      </a>
      <a
        href="mailto:bauke.brenninkmeijer@orq.ai"
        class="flex-1 text-center px-4 py-2.5 border border-border-dark light:border-border-light rounded-lg text-sm font-medium text-muted-dark light:text-muted-light hover:text-text-dark hover:border-text-dark light:hover:text-text-light light:hover:border-text-light transition-colors"
      >
        Email me
      </a>
    </div>
  </div>

  <!-- 4. Featured / upcoming -->
  <div class="flex flex-col items-center md:items-start gap-2 border-t border-border-dark light:border-border-light pt-6 mt-12">
    <span class="text-xs uppercase tracking-wider text-muted-dark light:text-muted-light">
      Upcoming
    </span>
    <a
      href={`${base}/talks`}
      class="text-sm text-muted-dark light:text-muted-light hover:text-text-dark light:hover:text-text-light transition-colors underline underline-offset-2"
    >
      Speaking at iO Engineering Manager Meetup — April 15, 2026
    </a>
  </div>

</section>

<style>
  .photo-pair:hover img:first-child {
    transform: translateX(-8px) translateY(-4px);
  }
  .photo-pair:hover img:last-child {
    transform: translateX(8px) translateY(4px);
  }
</style>
