---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const topics = [
  'AI Agents',
  'LLM Evaluation',
  'LLMOps',
  'Fine-tuning & Prompt Engineering',
  'Synthetic Data',
];
---

<section class="relative animate-fade-in max-w-5xl mx-auto px-6 py-28 md:py-36 flex flex-col">

  <!-- 1. Hero -->
  <div class="animate-fade-in flex flex-col md:flex-row items-center md:items-start gap-10 md:gap-16">

    <!-- Text block -->
    <div class="flex flex-col items-center md:items-start gap-5 flex-1 text-center md:text-left">
      <div>
        <h1 class="text-6xl md:text-7xl font-extrabold tracking-tighter text-text-dark light:text-text-light">
          Bauke Brenninkmeijer
        </h1>
        <p class="mt-3 text-lg md:text-xl leading-relaxed text-text-dark light:text-text-light max-w-xl">
          AI Research Engineer at orq.ai. I build AI agent infrastructure, evaluate LLMs, and write about getting models into production.
        </p>
      </div>

      <!-- CTA buttons -->
      <div class="flex items-center gap-3">
        <a
          href={`${base}/projects`}
          class="px-4 py-2 rounded text-sm font-medium bg-text-dark text-bg-dark light:bg-text-light light:text-bg-light hover:opacity-80 transition-opacity"
        >
          View Projects
        </a>
        <a
          href={`${base}/blog`}
          class="px-4 py-2 border border-border-dark light:border-border-light rounded text-sm font-medium text-muted-dark light:text-muted-light hover:text-text-dark hover:border-text-dark light:hover:text-text-light light:hover:border-text-light transition-colors"
        >
          Read Blog
        </a>
      </div>
    </div>

    <!-- Overlapping photos: real in front, cartoon behind -->
    <div class="flex-shrink-0 photo-pair relative w-60 h-52">
      <img
        src="/cartoon-avatar.jpg"
        alt="Cartoon avatar of Bauke"
        class="absolute left-0 top-4 w-40 h-40 rounded-full border-2 border-border-dark light:border-border-light object-cover z-10 transition-transform duration-300"
      />
      <img
        src="/profile.jpg"
        alt="Photo of Bauke Brenninkmeijer"
        class="absolute left-20 top-0 w-40 h-40 rounded-full border-2 border-border-dark light:border-border-light object-cover z-20 transition-transform duration-300"
      />
    </div>

  </div>

  <!-- 2. About -->
  <div class="reveal mt-24 border-t border-[#2a2a2a] light:border-border-light pt-10">
    <h2 class="text-2xl font-bold text-text-dark light:text-text-light mb-5">About</h2>
    <div class="space-y-4 text-base text-muted-dark light:text-muted-light leading-relaxed max-w-2xl">
      <p>
        I'm an AI Research Engineer with a background in data science and computer science. After working at several startups, I spent 5 years building ML systems at ABN AMRO and ING — from real-time streaming frameworks to RAG-based document processing.
      </p>
      <p>
        Now at <a href="https://orq.ai" class="underline hover:text-text-dark light:hover:text-text-light transition-colors">orq.ai</a>, I focus on AI agent infrastructure, LLM evaluation, and figuring out what actually makes models work in production.
      </p>
      <p>
        I co-organize the <a href="https://mlops.community/" class="underline hover:text-text-dark light:hover:text-text-light transition-colors">MLOps Community Amsterdam</a> meetup and speak at conferences about applied AI.
      </p>
    </div>
  </div>

  <!-- 3. Contact CTA card -->
  <div class="reveal mt-16 max-w-xl mx-auto md:mx-0 border border-border-dark light:border-border-light rounded-2xl p-8 md:p-10 bg-[#111111] light:bg-[#f5f5f5]">
    <p class="text-xs uppercase tracking-widest text-muted-dark light:text-muted-light mb-3">Get in touch</p>
    <h2 class="text-lg font-semibold text-text-dark light:text-text-light mb-2">Available for speaking and collaboration</h2>
    <p class="text-sm text-muted-dark light:text-muted-light mb-4">Interested in AI agents, LLM evaluation, or production ML? Let's talk.</p>

    <div class="flex gap-3">
      <a
        href="https://calendar.app.google/7ET48JSCNjYVgiLH7"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center px-4 py-2.5 rounded-lg text-sm font-semibold bg-text-dark text-bg-dark light:bg-text-light light:text-bg-light hover:opacity-80 transition-opacity"
      >
        Schedule a call
      </a>
      <a
        href="mailto:bauke.brenninkmeijer@orq.ai"
        class="flex-1 text-center px-4 py-2.5 border border-border-dark light:border-border-light rounded-lg text-sm font-medium text-muted-dark light:text-muted-light hover:text-text-dark hover:border-text-dark light:hover:text-text-light light:hover:border-text-light transition-colors"
      >
        Email me
      </a>
    </div>
  </div>

  <!-- 4. Technical Arsenal -->
  <div class="reveal mt-24 border-t border-[#2a2a2a] light:border-border-light pt-10">
    <h2 class="text-2xl font-bold text-text-dark light:text-text-light mb-6">Technical Arsenal</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div class="arsenal-col" style="--accent: 167 139 250;">
        <h3 class="arsenal-title">
          <span class="arsenal-dot"></span>
          AI & LLMs
        </h3>
        <div class="flex flex-wrap gap-2">
          {['LLM Evaluation', 'LLM-as-Judge', 'RAG', 'Prompt Engineering', 'Prompt Optimization', 'Model Training & Fine-tuning', 'Failure Taxonomies', 'Observability & Tracing'].map(s => (
            <span class="arsenal-pill">{s}</span>
          ))}
        </div>
      </div>
      <div class="arsenal-col" style="--accent: 52 211 153;">
        <h3 class="arsenal-title">
          <span class="arsenal-dot"></span>
          Agents
        </h3>
        <div class="flex flex-wrap gap-2">
          {['AI Agents', 'Agent Development Lifecycle', 'Agent Evaluation', 'Multi-agent Orchestration', 'Context Engineering', 'Tool Use', 'MCP', 'Agent Memory'].map(s => (
            <span class="arsenal-pill">{s}</span>
          ))}
        </div>
      </div>
      <div class="arsenal-col" style="--accent: 251 191 36;">
        <h3 class="arsenal-title">
          <span class="arsenal-dot"></span>
          Libraries & Tooling
        </h3>
        <div class="flex flex-wrap gap-2">
          {['Python', 'PyTorch', 'Claude Agent SDK', 'OpenAI SDK', 'Polars', 'Pandas', 'scikit-learn', 'Synthetic Data'].map(s => (
            <span class="arsenal-pill">{s}</span>
          ))}
        </div>
      </div>
    </div>
  </div>


</section>

<style>
  .photo-pair:hover img:first-child {
    transform: translateX(-12px) translateY(-6px);
  }
  .photo-pair:hover img:last-child {
    transform: translateX(12px) translateY(6px);
  }

  section::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .arsenal-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgb(var(--accent) / 0.35);
    color: #fafafa;
  }
  :root.light .arsenal-title {
    color: #0a0a0a;
  }
  .arsenal-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: rgb(var(--accent));
    box-shadow: 0 0 10px rgb(var(--accent) / 0.6);
  }
  .arsenal-pill {
    font-size: 13px;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    border: 1px solid rgb(var(--accent) / 0.35);
    background: rgb(var(--accent) / 0.1);
    color: rgb(var(--accent));
    cursor: default;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .arsenal-pill:hover {
    background: rgb(var(--accent) / 0.22);
    border-color: rgb(var(--accent) / 0.7);
    transform: translateY(-1px);
  }
  :root.light .arsenal-pill {
    background: rgb(var(--accent) / 0.14);
    border-color: rgb(var(--accent) / 0.5);
    color: rgb(var(--accent) / 0.95);
    filter: brightness(0.72) saturate(1.15);
  }
  :root.light .arsenal-pill:hover {
    background: rgb(var(--accent) / 0.24);
    border-color: rgb(var(--accent) / 0.75);
  }
</style>

<script>
  function setupReveal() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  }
  setupReveal();
  document.addEventListener('astro:after-swap', setupReveal);
</script>
