---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const topics = [
  'AI Agents',
  'LLM Evaluation',
  'LLMOps',
  'Fine-tuning & Prompt Engineering',
  'Synthetic Data',
];
---

<section class="animate-fade-in max-w-5xl mx-auto px-6 py-20 flex flex-col gap-20">

  <!-- 1. Hero -->
  <div class="flex flex-col md:flex-row items-center md:items-start gap-10 md:gap-16">

    <!-- Text block -->
    <div class="flex flex-col items-center md:items-start gap-5 flex-1 text-center md:text-left">
      <div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-text-dark light:text-text-light">
          Bauke Brenninkmeijer
        </h1>
        <p class="mt-3 text-base leading-relaxed text-muted-dark light:text-muted-light max-w-xl">
          AI Research Engineer at orq.ai. I build AI agent infrastructure, evaluate LLMs, and write about getting models into production.
        </p>
      </div>

      <!-- CTA buttons -->
      <div class="flex items-center gap-3">
        <a
          href={`${base}/projects`}
          class="px-4 py-2 border border-border-dark light:border-border-light rounded text-sm text-muted-dark light:text-muted-light hover:text-text-dark hover:border-text-dark light:hover:text-text-light light:hover:border-text-light transition-colors"
        >
          View Projects
        </a>
        <a
          href={`${base}/blog`}
          class="px-4 py-2 border border-border-dark light:border-border-light rounded text-sm text-muted-dark light:text-muted-light hover:text-text-dark hover:border-text-dark light:hover:text-text-light light:hover:border-text-light transition-colors"
        >
          Read Blog
        </a>
      </div>
    </div>

    <!-- Overlapping photos -->
    <div class="photo-group relative flex-shrink-0 w-36 h-28">
      <!-- Pokemon avatar — behind (z-10) -->
      <img
        src="/personal-homepage/pokemon-avatar.jpg"
        alt="Pokémon avatar of Bauke"
        class="pokemon-photo absolute left-0 top-0 w-28 h-28 rounded-full border-2 border-border-dark light:border-border-light object-cover z-10 transition-transform duration-300"
      />
      <!-- Real photo — in front (z-20) -->
      <img
        src="/personal-homepage/profile.jpg"
        alt="Photo of Bauke Brenninkmeijer"
        class="real-photo absolute left-16 top-0 w-28 h-28 rounded-full border-2 border-border-dark light:border-border-light object-cover z-20 transition-transform duration-300"
      />
    </div>

  </div>

  <!-- 2. What I do -->
  <div class="flex flex-col items-center md:items-start gap-4 text-center md:text-left">
    <div class="flex flex-wrap justify-center md:justify-start gap-2">
      {topics.map((topic) => (
        <span class="text-xs border border-border-dark light:border-border-light rounded-full px-3 py-1 text-muted-dark light:text-muted-light">
          {topic}
        </span>
      ))}
    </div>

    <p class="text-sm text-muted-dark light:text-muted-light">
      Available for speaking and collaboration
    </p>

    <div class="flex flex-wrap justify-center md:justify-start items-center gap-4 text-sm">
      <a
        href="mailto:bauke.brenninkmeijer@orq.ai"
        class="text-muted-dark light:text-muted-light hover:text-text-dark light:hover:text-text-light transition-colors underline underline-offset-2"
      >
        bauke.brenninkmeijer@orq.ai
      </a>
      <span class="text-border-dark light:text-border-light" aria-hidden="true">·</span>
      <a
        href="https://calendar.app.google/7ET48JSCNjYVgiLH7"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-dark light:text-muted-light hover:text-text-dark light:hover:text-text-light transition-colors underline underline-offset-2"
      >
        Schedule a call
      </a>
    </div>
  </div>

  <!-- 3. Featured / upcoming -->
  <div class="flex flex-col items-center md:items-start gap-2">
    <span class="text-xs uppercase tracking-wider text-muted-dark light:text-muted-light">
      Upcoming
    </span>
    <a
      href={`${base}/talks`}
      class="text-sm text-muted-dark light:text-muted-light hover:text-text-dark light:hover:text-text-light transition-colors underline underline-offset-2"
    >
      Speaking at iO Engineering Manager Meetup — April 15, 2026
    </a>
  </div>

</section>

<style>
  .photo-group:hover .real-photo {
    transform: translateX(20px);
  }

  .photo-group:hover .pokemon-photo {
    transform: translateX(-20px);
  }
</style>
