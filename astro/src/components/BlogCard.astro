---
interface Props {
  title: string;
  date: Date;
  description: string;
  image?: string;
  categories?: string[];
  slug: string;
}

const { title, date, description, image, categories, slug } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<a
  href={`${base}/blog/${slug}`}
  class="block border border-border-dark light:border-border-light rounded-lg overflow-hidden hover:-translate-y-0.5 hover:border-muted-dark light:hover:border-muted-light transition-all"
>
  {image ? (
    <div class="h-40 overflow-hidden bg-[#111] light:bg-[#e0e0e0]">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      />
    </div>
  ) : (
    <div class="h-40 overflow-hidden bg-[#111] light:bg-[#e0e0e0] flex items-center justify-center">
      <span class="text-xs text-muted-dark light:text-muted-light">No image</span>
    </div>
  )}

  <div class="p-4 flex flex-col gap-2">
    <time class="text-xs text-muted-dark light:text-muted-light" datetime={date.toISOString()}>
      {formattedDate}
    </time>

    <h2 class="font-bold text-sm text-text-dark light:text-text-light leading-snug">
      {title}
    </h2>

    <p class="text-xs text-muted-dark light:text-muted-light line-clamp-3 leading-relaxed">
      {description}
    </p>

    {categories && categories.length > 0 && (
      <div class="flex flex-wrap gap-1 mt-1">
        {categories.map((cat) => (
          <span class="text-[10px] border border-border-dark light:border-border-light rounded-full px-2 py-0.5 text-muted-dark light:text-muted-light">
            {cat}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
