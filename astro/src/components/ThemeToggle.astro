---
// 3-state theme toggle: dark → light → auto → dark
---

<button
  id="theme-toggle"
  aria-label="Toggle theme (dark / light / auto)"
  title="Toggle theme"
  class="flex items-center justify-center w-8 h-8 rounded transition-colors hover:text-text-dark light:hover:text-text-light focus:outline-none focus-visible:ring-2 focus-visible:ring-current"
>
  <!-- Moon icon (dark mode) -->
  <svg class="theme-icon" data-icon="dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>

  <!-- Sun icon (light mode) -->
  <svg class="theme-icon hidden" data-icon="light" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>

  <!-- Monitor icon (auto mode) -->
  <svg class="theme-icon hidden" data-icon="auto" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="4" width="20" height="14" rx="2" />
    <line x1="8" y1="21" x2="16" y2="21" />
    <line x1="12" y1="17" x2="12" y2="21" />
  </svg>
</button>

<script>
  type Mode = 'dark' | 'light' | 'auto';
  const ORDER: Mode[] = ['dark', 'light', 'auto'];

  function getMode(): Mode {
    const stored = localStorage.getItem('theme');
    if (stored === 'light' || stored === 'dark' || stored === 'auto') return stored;
    return 'dark';
  }

  function resolveMode(mode: Mode): 'light' | 'dark' {
    if (mode === 'auto') {
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }
    return mode;
  }

  function applyMode(mode: Mode) {
    const resolved = resolveMode(mode);
    document.documentElement.classList.toggle('light', resolved === 'light');
    document.querySelectorAll<SVGElement>('.theme-icon').forEach((el) => {
      el.classList.toggle('hidden', el.dataset.icon !== mode);
    });
    const btn = document.getElementById('theme-toggle');
    if (btn) btn.setAttribute('title', `Theme: ${mode}`);
  }

  function initToggle() {
    const button = document.getElementById('theme-toggle');
    if (!button) return;
    applyMode(getMode());

    if (!button.dataset.bound) {
      button.addEventListener('click', () => {
        const current = getMode();
        const next = ORDER[(ORDER.indexOf(current) + 1) % ORDER.length];
        localStorage.setItem('theme', next);
        applyMode(next);
      });
      button.dataset.bound = 'true';
    }
  }

  initToggle();
  document.addEventListener('astro:after-swap', initToggle);
</script>
